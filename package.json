{
  "name": "@exegia/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "uv sync --system-certs",
    "build": "docker build -t exegia-backend .",
    "dev": "uv run uvicorn app.main:app --reload --system-certs",
    "db:start": "supabase status > /dev/null 2>&1 || dotenvx run -fk ../../.env.keys -f .env.development -- supabase start",
    "db:stop": "supabase stop",
    "stop": "pkill -f 'app.main' || true && supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:pull": "dotenvx run -fk ../../.env.keys -f .env.development -- supabase db pull",
    "db:push": "dotenvx run -fk ../../.env.keys -f .env.development -- supabase db push",
    "db:diff": "supabase db diff --schema public",
    "db:new": "supabase migration new",
    "env:encrypt": "dotenvx encrypt -fk ../../.env.keys -f .env.development",
    "env:decrypt": "dotenvx decrypt -fk ../../.env.keys -f .env.development",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "clean": "rm -rf .venv **/__pycache__ .ruff_cache node_modules && supabase db reset",
    "mcp:setup": "uv run python setup_mcp.py --system-certs",
    "mcp:setup:import": "uv run python setup_mcp.py --import --system-certs",
    "mcp:import": "uv run python -m app.scripts.import_corpu --system-certs",
    "mcp:import:bibles": "uv run python setup_mcp.py --import --type bible --system-certs",
    "mcp:import:original": "uv run python setup_mcp.py --import --type original --system-certs",
    "mcp:import:commentaries": "uv run python setup_mcp.py --import --type commentary --system-certs",
    "mcp:test": "uv run python test_mcp_integration.py"
  },
  "dependencies": {
    "supabase": "^2.92.1"
  }
}
